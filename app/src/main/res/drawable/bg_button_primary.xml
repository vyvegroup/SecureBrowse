<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="135"
                android:endColor="#CCFF3B30"
                android:startColor="#CCFF6B4A"
                android:type="linear" />
            <corners android:radius="16dp" />
        </shape>
    </item>
    <item
        android:bottom="1.5dp"
        android:left="1.5dp"
        android:right="1.5dp"
        android:top="1.5dp">
        <shape android:shape="rectangle">
            <solid android:color="#14141A" />
            <corners android:radius="14.5dp" />
        </shape>
    </item>
    <item
        android:bottom="3dp"
        android:left="3dp"
        android:right="3dp"
        android:top="3dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="135"
                android:endColor="#12FF3B30"
                android:startColor="#08FF9500"
                android:type="linear" />
            <corners android:radius="13.5dp" />
        </shape>
    </item>
</layer-list>
