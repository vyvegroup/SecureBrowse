<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Primary gradient border button -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="135"
                android:endColor="#CCFF3B30"
                android:startColor="#CCFF6B4A"
                android:type="linear" />
            <corners android:radius="14dp" />
        </shape>
    </item>

    <!-- Inner dark fill -->
    <item
        android:bottom="1.5dp"
        android:left="1.5dp"
        android:right="1.5dp"
        android:top="1.5dp">
        <shape android:shape="rectangle">
            <solid android:color="#1A1A1F" />
            <corners android:radius="12.5dp" />
        </shape>
    </item>

    <!-- Inner subtle glow -->
    <item
        android:bottom="3dp"
        android:left="3dp"
        android:right="3dp"
        android:top="3dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="135"
                android:endColor="#15FF3B30"
                android:startColor="#0AFF9500"
                android:type="linear" />
            <corners android:radius="11.5dp" />
        </shape>
    </item>

</layer-list>
